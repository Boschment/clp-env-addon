#!/bin/bash
# Wrap entire script in a brace-group so bash parses the whole file before
# executing any of it. This prevents corruption when `install` replaces
# /usr/local/bin/clp-env-addon (i.e. ourselves) mid-run.
{
set -e

# CloudPanel Env Variables Addon
# Adds an "Env" tab to each site for managing environment variables.
# Source-of-truth lives in /opt/clp-env-addon and is re-applied to
# CloudPanel's Symfony app after every apt operation, so CloudPanel
# updates cannot break the addon.

ADDON_DIR="/opt/clp-env-addon"
DATA_DIR="$ADDON_DIR/data"
CLP_APP="/home/clp/htdocs/app/files"
CLP_TEMPLATES="$CLP_APP/templates/Frontend/Site"
CLP_CONTROLLERS="$CLP_APP/src/Controller/Frontend"
CLP_CSS="$CLP_APP/public/assets/css/frontend"
CLP_ROUTES="$CLP_APP/config/routes.yaml"
TAB_TEMPLATE="$CLP_TEMPLATES/Partial/tab-container.html.twig"
SUDOERS_FILE="/etc/sudoers.d/clp-env-addon"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_ok()   { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_err()  { echo -e "${RED}[ERROR]${NC} $1"; }

check_root() {
    if [ "$EUID" -ne 0 ]; then
        log_err "This script must be run as root."
        exit 1
    fi
}

is_patched() {
    grep -q "clp_site_env" "$CLP_ROUTES" 2>/dev/null && \
    grep -q "'env'" "$TAB_TEMPLATE" 2>/dev/null
}

patch_tab_container() {
    if grep -q "clp_site_env" "$TAB_TEMPLATE" 2>/dev/null; then
        log_ok "Env tab already present in tab-container.html.twig"
        return 0
    fi

    sed -i '/<\/ul>/i\    <li {% if active == '\''env'\'' %}class="active"{% endif %}>\n      <a href="{{ path('\''clp_site_env'\'', {'\''domainName'\'': site.domainName}) }}">{% trans %}Variables{% endtrans %}<\/a>\n    <\/li>' "$TAB_TEMPLATE"

    if grep -q "clp_site_env" "$TAB_TEMPLATE"; then
        log_ok "Env tab added to tab-container.html.twig"
    else
        log_err "Failed to patch tab-container.html.twig"
        return 1
    fi
}

patch_routes() {
    if grep -q "clp_site_env:" "$CLP_ROUTES" 2>/dev/null; then
        log_ok "Routes already present in routes.yaml"
        return 0
    fi

    cat >> "$CLP_ROUTES" << 'ROUTES'

# CloudPanel Env Variables Addon
clp_site_env:
  path: /site/{domainName}/env
  controller: App\Controller\Frontend\EnvController::index

clp_site_env_save:
  path: /site/{domainName}/env/save
  controller: App\Controller\Frontend\EnvController::save
  methods: POST

clp_site_env_delete:
  path: /site/{domainName}/env/delete
  controller: App\Controller\Frontend\EnvController::delete
  methods: POST
ROUTES

    if grep -q "clp_site_env:" "$CLP_ROUTES"; then
        log_ok "Routes added to routes.yaml"
    else
        log_err "Failed to patch routes.yaml"
        return 1
    fi
}

copy_files() {
    cp "$ADDON_DIR/src/Controller/Frontend/EnvController.php" "$CLP_CONTROLLERS/EnvController.php"
    cp "$ADDON_DIR/templates/Frontend/Site/env.html.twig" "$CLP_TEMPLATES/env.html.twig"
    cp "$ADDON_DIR/public/assets/css/frontend/env.css" "$CLP_CSS/env.css"

    chown clp:clp "$CLP_CONTROLLERS/EnvController.php" "$CLP_TEMPLATES/env.html.twig" "$CLP_CSS/env.css"
    chmod 770 "$CLP_CONTROLLERS/EnvController.php" "$CLP_TEMPLATES/env.html.twig" "$CLP_CSS/env.css"

    log_ok "Addon files copied into CloudPanel"
}

ensure_data_dir() {
    mkdir -p "$DATA_DIR"
    chown clp:clp "$DATA_DIR"
    chmod 750 "$DATA_DIR"
    log_ok "Data directory ready at $DATA_DIR"
}

install_sudoers() {
    # Narrow sudo grants for the clp (web UI) user.
    cat > "$SUDOERS_FILE" << 'SUDO'
# CloudPanel Env Variables Addon
clp ALL=(root) NOPASSWD: /usr/local/bin/clp-env-pool-update, /usr/local/bin/clp-env-pm2-reload
SUDO
    chmod 440 "$SUDOERS_FILE"
    # Validate; if invalid, remove so we don't lock anything out.
    if ! visudo -c -f "$SUDOERS_FILE" >/dev/null 2>&1; then
        rm -f "$SUDOERS_FILE"
        log_warn "sudoers snippet failed validation and was removed"
    else
        log_ok "sudoers snippet installed at $SUDOERS_FILE"
    fi
}

ensure_dependencies() {
    if ! command -v python3 >/dev/null 2>&1; then
        log_warn "python3 not installed, installing..."
        apt-get install -y python3 >/dev/null 2>&1 && log_ok "python3 installed" || log_err "failed to install python3"
    fi
}

clear_cache() {
    su -s /bin/bash -c "cd $CLP_APP && php bin/console cache:clear --env=prod 2>&1" clp > /dev/null
    log_ok "Symfony cache cleared"
}

install_apt_hook() {
    local hook_file="/etc/apt/apt.conf.d/99-clp-env-addon"
    cat > "$hook_file" << 'HOOK'
DPkg::Post-Invoke { "if [ -x /usr/local/bin/clp-env-addon ]; then /usr/local/bin/clp-env-addon repair --quiet 2>/dev/null || true; fi"; };
HOOK
    log_ok "APT hook installed at $hook_file"
}

cmd_install() {
    check_root
    echo "Installing CloudPanel Env Variables Addon..."
    echo ""

    if [ ! -d "$ADDON_DIR" ]; then
        log_err "Addon source not found at $ADDON_DIR"
        log_err "Clone/copy the addon files to $ADDON_DIR first."
        exit 1
    fi

    if [ ! -d "$CLP_APP" ]; then
        log_err "CloudPanel not found at $CLP_APP"
        exit 1
    fi

    ensure_dependencies
    ensure_data_dir
    copy_files
    patch_tab_container
    patch_routes
    install_sudoers
    clear_cache
    install_apt_hook

    # Use `install` (atomic: temp file + rename) so the running script's
    # file descriptor remains valid even though we are overwriting ourselves.
    install -m 755 -o root -g root "$ADDON_DIR/scripts/clp-env-addon"        /usr/local/bin/clp-env-addon
    install -m 755 -o root -g root "$ADDON_DIR/scripts/clp-env-pm2-reload"   /usr/local/bin/clp-env-pm2-reload
    install -m 755 -o root -g root "$ADDON_DIR/scripts/clp-env-pool-update"  /usr/local/bin/clp-env-pool-update

    echo ""
    log_ok "Installation complete!"
    echo ""
    echo "  Open CloudPanel and navigate to any site."
    echo "  You should see a new 'Variables' tab."
    echo ""
}

cmd_repair() {
    local quiet=false
    [ "$1" = "--quiet" ] && quiet=true

    if is_patched && \
       [ -f "$CLP_CONTROLLERS/EnvController.php" ] && \
       [ -f "$CLP_TEMPLATES/env.html.twig" ] && \
       [ -f "$CLP_CSS/env.css" ]; then
        $quiet || log_ok "All patches intact, nothing to repair."
        return 0
    fi

    $quiet || echo "Repairing CloudPanel Env Variables Addon..."

    if [ ! -d "$ADDON_DIR" ]; then
        $quiet || log_err "Addon source not found at $ADDON_DIR - cannot repair."
        return 1
    fi

    copy_files
    patch_tab_container
    patch_routes
    clear_cache

    $quiet || log_ok "Repair complete!"
}

cmd_check() {
    echo "Checking CloudPanel Env Variables Addon status..."
    echo ""
    local all_ok=true

    [ -f "$CLP_CONTROLLERS/EnvController.php" ] && log_ok "EnvController.php present" || { log_err "EnvController.php MISSING"; all_ok=false; }
    [ -f "$CLP_TEMPLATES/env.html.twig" ]      && log_ok "env.html.twig present"      || { log_err "env.html.twig MISSING"; all_ok=false; }
    [ -f "$CLP_CSS/env.css" ]                  && log_ok "env.css present"            || { log_err "env.css MISSING"; all_ok=false; }
    grep -q "clp_site_env" "$CLP_ROUTES" 2>/dev/null && log_ok "Routes configured"    || { log_err "Routes MISSING"; all_ok=false; }
    grep -q "clp_site_env" "$TAB_TEMPLATE" 2>/dev/null && log_ok "Variables tab present" || { log_err "Variables tab MISSING"; all_ok=false; }
    [ -f "/etc/apt/apt.conf.d/99-clp-env-addon" ]       && log_ok "APT hook installed"          || log_warn "APT hook not installed"
    [ -f "/usr/local/bin/clp-env-pool-update" ]         && log_ok "Pool update helper present"   || { log_err "Pool update helper MISSING"; all_ok=false; }
    [ -d "$DATA_DIR" ]                         && log_ok "Data directory present"     || { log_err "Data directory MISSING"; all_ok=false; }

    echo ""
    $all_ok && log_ok "Everything looks good!" || log_err "Issues detected. Run 'clp-env-addon repair' to fix."
}

cmd_uninstall() {
    check_root
    echo "Uninstalling CloudPanel Env Variables Addon..."

    rm -f "$CLP_CONTROLLERS/EnvController.php"
    rm -f "$CLP_TEMPLATES/env.html.twig"
    rm -f "$CLP_CSS/env.css"

    # Remove route block (from header comment to last route line we added).
    sed -i '/# CloudPanel Env Variables Addon/,/methods: POST$/d' "$CLP_ROUTES" 2>/dev/null || true
    # Catch any stragglers if the block was edited.
    sed -i '/clp_site_env/,/methods: POST$/d' "$CLP_ROUTES" 2>/dev/null || true

    # Remove our tab line.
    sed -i "/clp_site_env/d" "$TAB_TEMPLATE"
    sed -i "/{% if active == 'env' %}/d" "$TAB_TEMPLATE" 2>/dev/null || true

    rm -f /etc/apt/apt.conf.d/99-clp-env-addon
    rm -f "$SUDOERS_FILE"
    rm -f /usr/local/bin/clp-env-pm2-reload
    rm -f /usr/local/bin/clp-env-pool-update

    clear_cache

    log_ok "Addon removed from CloudPanel."
    log_warn "Stored variables in $DATA_DIR were NOT removed."
    log_warn "Per-site PHP-FPM pool blocks were NOT removed."
    log_warn "To remove completely: rm -rf $ADDON_DIR /usr/local/bin/clp-env-addon $DATA_DIR"
}

case "${1:-}" in
    install)   cmd_install ;;
    repair)    cmd_repair "${2:-}" ;;
    check)     cmd_check ;;
    uninstall) cmd_uninstall ;;
    *)
        echo "CloudPanel Env Variables Addon"
        echo ""
        echo "Usage: clp-env-addon <command>"
        echo ""
        echo "Commands:"
        echo "  install     Install the addon into CloudPanel"
        echo "  repair      Re-apply patches (runs automatically after apt operations)"
        echo "  check       Verify addon status"
        echo "  uninstall   Remove addon from CloudPanel"
        echo ""
        ;;
esac
exit $?
}
