{% extends 'Frontend/layout.html.twig' %}

{% block pageTitle %}{% trans %}Environment Variables{% endtrans %}{% endblock %}

{%- block stylesheets -%}
  {{ parent() }}
  <link href="{{ asset('/assets/css/frontend/site.css') }}" rel="stylesheet">
  <link href="{{ asset('/assets/css/frontend/env.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="container-fluid container-limited-width">
  <div class="site-container">
    {{ include('Frontend/Site/Partial/site-info.html.twig', {'site': site}) }}
    <div class="site-content-container">
      {{ include('Frontend/Site/Partial/tab-container.html.twig', {'active': 'env', 'site': site}) }}
      {{ include('Partial/flash-messages.html.twig', { 'flashBagMessages': app.session.flashbag.all }) }}
      <div class="site-content">

        <div class="card">
          <div class="card-header">
            {% trans %}Add Variable{% endtrans %}
          </div>
          <div class="card-body">
            <form method="post" action="{{ path('clp_site_env_save', {'domainName': site.domainName}) }}?token={{ csrf_token('env-save') }}" class="row g-2 align-items-end">
              <div class="col-md-4">
                <label class="form-label" for="env-key">{% trans %}Key{% endtrans %}</label>
                <input type="text" id="env-key" name="key" class="form-control text-monospace" placeholder="DATABASE_URL" pattern="[A-Z_][A-Z0-9_]*" required>
                <div class="form-text absolute">{% trans %}A-Z, 0-9 and _ only. Must start with a letter or underscore.{% endtrans %}</div>
              </div>
              <div class="col-md-6">
                <label class="form-label" for="env-value">{% trans %}Value{% endtrans %}</label>
                <input type="text" id="env-value" name="value" class="form-control text-monospace" placeholder="postgres://..." autocomplete="off">
              </div>
              <div class="col-md-2">
                <button type="submit" class="btn btn-blue w-100">{% trans %}Save{% endtrans %}</button>
              </div>
            </form>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            {% trans %}Variables{% endtrans %}
          </div>
          <div class="card-body card-body-no-padding">
            {% if variables is empty %}
              <p class="text-muted p-3 mb-0">{% trans %}No variables defined yet.{% endtrans %}</p>
            {% else %}
              <table class="table table-env-variables mb-0">
                <thead>
                  <tr>
                    <th style="width: 30%">{% trans %}Key{% endtrans %}</th>
                    <th>{% trans %}Value{% endtrans %}</th>
                    <th class="text-end" style="width: 120px">{% trans %}Actions{% endtrans %}</th>
                  </tr>
                </thead>
                <tbody>
                  {% for key, value in variables %}
                    <tr>
                      <td><code>{{ key }}</code></td>
                      <td>
                        <code class="env-value-cell" data-value="{{ value }}">
                          <span class="env-value-mask">••••••••</span>
                          <span class="env-value-real d-none">{{ value }}</span>
                        </code>
                      </td>
                      <td class="text-end">
                        <button type="button" class="btn btn-sm btn-outline-secondary env-toggle">{% trans %}Show{% endtrans %}</button>
                        <form method="post" action="{{ path('clp_site_env_delete', {'domainName': site.domainName}) }}?token={{ csrf_token('env-delete') }}" class="d-inline" onsubmit="return confirm('{% trans %}Delete this variable?{% endtrans %}');">
                          <input type="hidden" name="key" value="{{ key }}">
                          <button type="submit" class="btn btn-sm btn-outline-danger">{% trans %}Delete{% endtrans %}</button>
                        </form>
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            {% endif %}
          </div>
        </div>

        <div class="card">
          <div class="card-header">{% trans %}How variables are applied{% endtrans %}</div>
          <div class="card-body">
            <p class="mb-1">{% trans %}On save, this addon:{% endtrans %}</p>
            <ul class="mb-0">
              <li>{% trans %}Writes{% endtrans %} <code>env[KEY] = "value"</code> {% trans %}into the PHP-FPM pool and reloads PHP-FPM (available in PHP via{% endtrans %} <code>$_SERVER['KEY']</code> / <code>getenv('KEY')</code>).</li>
              <li>{% trans %}Auto-detects PM2 apps for this site (matched by working directory) and restarts them with{% endtrans %} <code>pm2 restart &lt;app&gt; --update-env</code> {% trans %}so they pick up the new variables in{% endtrans %} <code>process.env</code>. {% trans %}No{% endtrans %} <code>.env</code> {% trans %}or{% endtrans %} <code>ecosystem.config.js</code> {% trans %}is written.{% endtrans %}</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascript %}
  {{ parent() }}
  <script type="text/javascript">
  jQuery(document).ready(function() {
    jQuery('.env-toggle').on('click', function() {
      var row = jQuery(this).closest('tr');
      var mask = row.find('.env-value-mask');
      var real = row.find('.env-value-real');
      var hidden = real.hasClass('d-none');
      mask.toggleClass('d-none', hidden);
      real.toggleClass('d-none', !hidden);
      jQuery(this).text(hidden ? '{% trans %}Hide{% endtrans %}' : '{% trans %}Show{% endtrans %}');
    });
  });
  </script>
{% endblock %}
